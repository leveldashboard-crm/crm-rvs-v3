# ─── Supabase PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL="postgres://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate a secret by running: npx auth secret
AUTH_SECRET="your_generated_secret_here"
# NEXTAUTH_URL is NOT needed — trustHost:true auto-detects on Vercel.

# ─── Admin Seed Key ───────────────────────────────────────────────────────────
# Used to seed initial admin. Replace with a secure random string in production.
ADMIN_SECRET_KEY="delegate-admin-seed-2024"
