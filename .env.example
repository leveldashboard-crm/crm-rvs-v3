# ─── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Transaction pooler URL (port 6543) — used by Next.js API routes
DATABASE_URL="postgres://user:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require"

# ─── NextAuth v5 ──────────────────────────────────────────────────────────────
# Generate a secure secret by running: npx auth secret
# This is REQUIRED — the app will throw on startup if missing.
AUTH_SECRET="your_generated_secret_here"
# NEXTAUTH_URL is NOT needed — trustHost:true auto-detects the domain on Vercel.

# ─── Admin Seed Key ───────────────────────────────────────────────────────────
# Protects the /api/setup?key=... endpoint. Replace with a secure random string.
# Generate: openssl rand -base64 32
ADMIN_SECRET_KEY="delegate-admin-seed-2024"

# ─── Session Timeout ──────────────────────────────────────────────────────────
# Override the default 30-minute inactivity timeout (configured via Settings UI)
# SESSION_TIMEOUT_MINUTES=30
